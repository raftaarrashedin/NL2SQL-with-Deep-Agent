# LLM Providers
OPENAI_API_KEY=""
GROQ_API_KEY=""
HUGGINGFACEHUB_API_TOKEN=""
# OLLAMA doesn't usually need a key if local, but can specify host
OLLAMA_HOST="http://host.docker.internal:11434"

# Default selected provider (openai, groq, huggingface, ollama)
DEFAULT_LLM_PROVIDER="openai"
DEFAULT_MODEL="gpt-4o"
DEFAULT_SQL_MODEL=""
MAX_CHAT_HISTORY_MESSAGES="30"
MAX_SQL_EXECUTION_ATTEMPTS="2"

# Database connection for App Internal Storage
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="nl2sql_app"
POSTGRES_HOST="db"
POSTGRES_PORT="5432"

# SQLAlchemy URL
DATABASE_URL="postgresql://postgres:password@db:5432/nl2sql_app"
